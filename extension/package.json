{
  "name": "agentflow-live",
  "displayName": "AgentFlow Live",
  "description": "Real-time visualization of Claude Code and Codex agent orchestration",
  "version": "1.0.0",
  "publisher": "codex-tools",
  "author": "David",
  "license": "Apache-2.0",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/patoles/agent-flow"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "llm",
    "agent",
    "claude",
    "codex",
    "ai",
    "visualization",
    "orchestration"
  ],
  "activationEvents": [
    "onWebviewPanel:agentVisualizer",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentflow-live",
          "title": "AgentFlow Live",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "agentflow-live": [
        {
          "id": "agentFlowLive.launcher",
          "name": "AgentFlow Live"
        }
      ]
    },
    "commands": [
      {
        "command": "agentVisualizer.open",
        "title": "Open Agent Flow",
        "category": "Agent Flow"
      },
      {
        "command": "agentVisualizer.openToSide",
        "title": "Open Agent Flow to Side",
        "category": "Agent Flow"
      },
      {
        "command": "agentVisualizer.connectToAgent",
        "title": "Connect to Running Agent",
        "category": "Agent Flow"
      },
      {
        "command": "agentVisualizer.configureHooks",
        "title": "Configure Claude Code Hooks",
        "category": "Agent Flow"
      }
    ],
    "keybindings": [
      {
        "command": "agentVisualizer.open",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "agentVisualizer.open",
        "key": "ctrl+alt+shift+a",
        "mac": "cmd+alt+shift+a"
      }
    ],
    "configuration": {
      "title": "Agent Flow",
      "properties": {
        "agentVisualizer.devServerPort": {
          "type": "number",
          "default": 0,
          "description": "Port for the development server. Set to 0 (default) for production mode, or 3002 for development."
        },
        "agentVisualizer.eventLogPath": {
          "type": "string",
          "default": "",
          "description": "Path to JSONL event log file to watch for agent events"
        },
        "agentVisualizer.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the visualizer when an agent session starts"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "cp ../README.md ./README.md && npm run build:all",
    "build": "node esbuild.js",
    "build:webview": "cd ../web && pnpm run build:webview",
    "build:all": "npm run build:webview && npm run build",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "lint": "tsc --noEmit",
    "vscode:uninstall": "node scripts/uninstall.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
